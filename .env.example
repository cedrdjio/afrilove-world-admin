# ─── AfroLove World Admin — environment variables ───
# Copy to .env.local for local dev, and set these in Vercel project settings.
# NEVER commit real secrets. Rotate any key that has been shared in plain text.
#
# The app reads only THREE values at runtime, all server-side:
#   1. the Supabase project URL
#   2. the Supabase service-role key
#   3. AUTH_SECRET (signs admin session cookies)
#
# Both the canonical names below AND the `afro_`-prefixed Vercel names are
# accepted (see src/lib/env.ts), so you don't have to rename anything.

# Supabase URL — any one of these works:
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
#   alias: NEXT_PUBLIC_afro_SUPABASE_URL

# Service-role key (server-only, NEVER exposed to the browser):
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
#   alias: afro_SUPABASE_SERVICE_ROLE_KEY

# Session signing secret — generate with: openssl rand -base64 48
# (falls back to afro_SUPABASE_JWT_SECRET if AUTH_SECRET is not set)
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional — anon key (not used at runtime; handy for reference/tools):
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Optional — OneSignal push notifications:
ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""
