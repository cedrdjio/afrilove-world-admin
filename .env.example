# ─── AfriLove World Admin — environment variables ───
# Copy to .env.local for local dev, and set these in Vercel project settings.
# NEVER commit real secrets. Rotate any key that has been shared in plain text.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only (NEVER exposed to the browser). Used by server actions / RSC.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth — secret used to sign the admin session JWT. Generate a long random value:
#   openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional: OneSignal push notifications
ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""
